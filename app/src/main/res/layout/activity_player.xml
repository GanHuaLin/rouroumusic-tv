<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".PlayerActivity">

    <!-- 1. Background: Fullscreen Cover with Blur & Dim -->
    <!-- Main Content Container (to facilitate focus locking) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutMainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/ivBlurBackground"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:alpha="0.4"
            android:src="@drawable/ic_album_placeholder"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/viewOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_player_overlay"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Guide Lines for Split -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideSplit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.45" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.82" />

        <!-- 2. Left Side: Album Cover & Metadata (Centered vertically in its area) -->
        <!-- Album Cover: Smaller Size (was 0.38) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCover"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.27"
            app:cardCornerRadius="54dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#00000000"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tvBigTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideSplit"
            app:layout_constraintVertical_chainStyle="packed"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/ivBigCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_album_placeholder" />
        </androidx.cardview.widget.CardView>

        <!-- Song Title: Centered, Marquee - Smaller -->
        <cc.ganhualin.xiaomusictv.MarqueeTextView
            android:id="@+id/tvBigTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Song Title"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintWidth_percent="0.27"
            app:layout_constraintTop_toBottomOf="@+id/cardCover"
            app:layout_constraintBottom_toTopOf="@+id/tvBigArtist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideSplit"
            android:layout_marginBottom="4dp"/>

        <!-- Artist Name: Centered - Smaller -->
        <cc.ganhualin.xiaomusictv.MarqueeTextView
            android:id="@+id/tvBigArtist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Artist Name"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            app:layout_constraintWidth_percent="0.20"
            app:layout_constraintTop_toBottomOf="@+id/tvBigTitle"
            app:layout_constraintBottom_toTopOf="@+id/guideBottom"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideSplit" />

        <!-- 3. Right Side: Lyrics -->
        <!-- Added padding bottom to avoid overlap controls -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLyrics"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingTop="200dp"
            android:paddingBottom="200dp"
            android:scrollbars="none"
            android:focusable="false"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="48dp"
            android:overScrollMode="never"
            app:layout_constraintBottom_toTopOf="@+id/guideBottom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guideSplit"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Screen Top Fade Gradient (Gaussian Mimic) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/bg_lyrics_fade_top"
            android:focusable="false"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Screen Bottom Fade Gradient (Gaussian Mimic) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_lyrics_fade_bottom"
            android:focusable="false"
            app:layout_constraintBottom_toBottomOf="parent" />
            
        <TextView
            android:id="@+id/tvNoLyrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无歌词"
            android:textColor="#66FFFFFF"
            android:textSize="24sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/guideBottom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guideSplit"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 4. Bottom Controls Area -->
        
        <!-- Large Center Seek Progress - For long press gestures -->
        <LinearLayout
            android:id="@+id/layoutSeekProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:elevation="10dp"
            android:layout_marginBottom="100dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            
            <TextView
                android:id="@+id/tvSeekProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tooltip_rect"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:gravity="center"
                android:singleLine="true"
                android:text="▶▶ 00:00/00:00" />
        </LinearLayout>

        <!-- 4. Bottom Controls Area - Wrapped in a container for animation -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutBottomControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_controls_gradient"
            android:paddingTop="60dp"
            android:paddingBottom="0dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Tooltip (Bubble) tracking the thumb - Attached to progress bar -->
            <LinearLayout
                android:id="@+id/layoutTooltip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="invisible"
                android:elevation="6dp"
                android:layout_marginBottom="18dp"
                app:layout_constraintStart_toStartOf="@+id/progressBar"
                app:layout_constraintBottom_toBottomOf="@+id/progressBar">
                
                <TextView
                    android:id="@+id/tvTooltip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tooltip_rect"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="00:00/00:00" />
                    
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="6dp"
                    android:src="@drawable/ic_tooltip_arrow" />
            </LinearLayout>

            <!-- Progress Bar: Focusable -->
            <SeekBar
                android:id="@+id/progressBar"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:minHeight="24dp"
                android:maxHeight="24dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:splitTrack="false"
                android:progressDrawable="@drawable/bg_progress"
                android:progressTint="#FFFFFF"
                android:progressBackgroundTint="#4DFFFFFF"
                android:thumb="@drawable/selector_thumb"
                android:focusable="true"
                android:nextFocusUp="@+id/progressBar"
                android:nextFocusLeft="@+id/progressBar"
                android:nextFocusRight="@+id/progressBar"
                android:nextFocusDown="@+id/btnPlayPause"
                app:layout_constraintWidth_percent="0.9"
                app:layout_constraintBottom_toTopOf="@+id/btnPlayPause"
                android:layout_marginBottom="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Time Container BELOW Progress Bar -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutTimeContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="-8dp"
                app:layout_constraintStart_toStartOf="@+id/progressBar"
                app:layout_constraintEnd_toEndOf="@+id/progressBar"
                app:layout_constraintTop_toBottomOf="@+id/progressBar">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="60dp"
                    android:layout_height="20dp"
                    android:gravity="center"
                    android:text="00:00"
                    android:textColor="#DDDDDD"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="60dp"
                    android:layout_height="20dp"
                    android:gravity="center"
                    android:text="00:00"
                    android:textColor="#DDDDDD"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- CENTER GROUP: Prev, Play, Next -->
            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/btn_focused_circle"
                android:src="@drawable/ic_play"
                android:scaleType="fitCenter"
                android:padding="12dp"
                android:contentDescription="PlayPause"
                android:focusable="true"
                android:nextFocusUp="@+id/progressBar"
                android:nextFocusLeft="@+id/btnPrev"
                android:nextFocusRight="@+id/btnNext"
                android:nextFocusDown="@+id/btnPlayPause"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <requestFocus />
            </ImageButton>

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/btn_focused_circle"
                android:src="@drawable/ic_skip_previous"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:contentDescription="Previous"
                android:focusable="true"
                android:nextFocusUp="@+id/progressBar"
                android:nextFocusLeft="@+id/btnQueue"
                android:nextFocusRight="@+id/btnPlayPause"
                android:nextFocusDown="@+id/btnPrev"
                app:layout_constraintEnd_toStartOf="@+id/btnPlayPause"
                app:layout_constraintTop_toTopOf="@+id/btnPlayPause"
                app:layout_constraintBottom_toBottomOf="@+id/btnPlayPause"/>

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/btn_focused_circle"
                android:src="@drawable/ic_skip_next"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:contentDescription="Next"
                android:focusable="true"
                android:nextFocusUp="@+id/progressBar"
                android:nextFocusLeft="@+id/btnPlayPause"
                android:nextFocusRight="@+id/btnRepeat"
                android:nextFocusDown="@+id/btnNext"
                app:layout_constraintStart_toEndOf="@+id/btnPlayPause"
                app:layout_constraintTop_toTopOf="@+id/btnPlayPause"
                app:layout_constraintBottom_toBottomOf="@+id/btnPlayPause"/>

            <!-- LEFT GROUP: Playlist -->
            <ImageButton
                android:id="@+id/btnQueue"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginBottom="32dp"
                android:layout_marginStart="48dp"
                android:background="@drawable/btn_focused_circle"
                android:src="@drawable/ic_queue_music"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:contentDescription="Queue"
                android:focusable="true"
                android:nextFocusUp="@+id/progressBar"
                android:nextFocusRight="@+id/btnPrev"
                android:nextFocusLeft="@+id/btnQueue"
                android:nextFocusDown="@+id/btnQueue"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- RIGHT GROUP: Mode, Fav -->
            <ImageButton
                android:id="@+id/btnFav"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="48dp"
                android:background="@drawable/btn_focused_circle"
                android:src="@drawable/ic_favorite_border"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:alpha="0.8"
                android:contentDescription="Favorite"
                android:focusable="true"
                android:nextFocusUp="@+id/progressBar"
                android:nextFocusLeft="@+id/btnRepeat"
                android:nextFocusRight="@+id/btnFav"
                android:nextFocusDown="@+id/btnFav"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/btnQueue"
                app:layout_constraintBottom_toBottomOf="@+id/btnQueue"/>

            <ImageButton
                android:id="@+id/btnRepeat"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/btn_focused_circle"
                android:src="@drawable/ic_repeat"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:alpha="0.8"
                android:contentDescription="Mode"
                android:focusable="true"
                android:nextFocusUp="@+id/progressBar"
                android:nextFocusLeft="@+id/btnNext"
                android:nextFocusRight="@+id/btnFav"
                android:nextFocusDown="@+id/btnRepeat"
                app:layout_constraintEnd_toStartOf="@+id/btnFav"
                app:layout_constraintTop_toTopOf="@+id/btnQueue"
                app:layout_constraintBottom_toBottomOf="@+id/btnQueue"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 5. Sidebar Drawer (hidden by default) -->
    <!-- Full screen container for the dim effect -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutDrawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:descendantFocusability="afterDescendants"
        android:nextFocusLeft="@id/layoutDrawer"
        android:nextFocusRight="@id/layoutDrawer"
        android:nextFocusUp="@id/layoutDrawer"
        android:nextFocusDown="@id/layoutDrawer"
        android:elevation="50dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Shadow View: Exactly 1/3 of screen width -->
        <View
            android:id="@+id/viewDrawerShadow"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_drawer_dim"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_percent="0.6"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="40dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:clipToPadding="false"
            android:clipChildren="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_percent="0.6"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="24dp"
                android:layout_marginStart="12dp">
                
                <TextView
                    android:id="@+id/tvDrawerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="播放列表"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPlaylistName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#B3FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="3dp" />

                <TextView
                    android:id="@+id/tvPlaylistCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="3dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDrawerSongs"
                android:layout_width="280dp"
                android:layout_height="match_parent"
                android:focusable="true"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:scrollbars="none"
                android:nextFocusLeft="@id/rvDrawerSongs"
                android:nextFocusRight="@id/rvDrawerSongs" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 6. Right Sidebar Menu (Option Menu) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutOptionMenu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:elevation="60dp">

        <!-- Dim Background -->
        <View
            android:id="@+id/viewOptionMenuDim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#99000000" />

        <!-- Menu Content: Right 30% -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_controls_gradient"
            android:rotation="180"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.3">
            
            <!-- Rotate back the contents -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:rotation="180"
                android:paddingTop="60dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="歌曲操作"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:padding="24dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvOptions"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="8dp"
                    android:clipToPadding="false"
                    android:scrollbars="none" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
