<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient">

    <!-- Top Left Header: Logo + Settings -->
    <LinearLayout
        android:id="@+id/layoutHeaderLeft"
        android:layout_width="300dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:background="#40000000"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_logo"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="肉肉音乐"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F3F4F6"
            android:layout_marginStart="12dp"/>

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/btn_focused_circle"
            android:src="@drawable/ic_settings"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="#9CA3AF"
            android:focusable="true"
            android:nextFocusDown="@+id/rvPlaylists"
            android:nextFocusRight="@+id/rvSongs"
            android:contentDescription="Settings" />

    </LinearLayout>

    <!-- Top Right Header: Playlist Name + Count -->
    <LinearLayout
        android:id="@+id/layoutHeaderRight"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintStart_toEndOf="@+id/layoutHeaderLeft"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvPlaylistTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="所有歌曲"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#F3F4F6"
            android:focusable="true" 
            android:focusableInTouchMode="false"
            android:nextFocusLeft="@+id/btnSettings"
            android:nextFocusDown="@+id/rvSongs"/>

        <TextView
            android:id="@+id/tvSongCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 首歌曲"
            android:textSize="14sp"
            android:textColor="#9CA3AF" />

    </LinearLayout>

    <!-- Left Column: Playlists + Mini Player -->
    <LinearLayout
        android:id="@+id/leftColumn"
        android:layout_width="300dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#40000000"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutHeaderLeft"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Playlists List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlaylists"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:nextFocusUp="@+id/btnSettings"
            android:nextFocusDown="@+id/btnOpenPlayer"
            android:nextFocusRight="@+id/rvSongs"/>

        <!-- Mini Player Footer -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutPlayer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:background="#E6111827"
            android:elevation="8dp"
            android:padding="8dp">

            <!-- 1. Open Player Group (Cover + Info) -->
            <LinearLayout
                android:id="@+id/btnOpenPlayer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/selector_item_bg"
                android:focusable="true"
                android:clickable="true"
                android:padding="6dp"
                android:paddingEnd="96dp"
                android:nextFocusUp="@+id/rvPlaylists"
                android:nextFocusRight="@+id/btnPlayPause"
                android:nextFocusDown="@+id/btnOpenPlayer"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="0dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cvCurrentCover"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#374151">

                    <ImageView
                        android:id="@+id/ivCurrentCover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="cover" />
                        
                    <!-- CD Hole -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#111827" />
                        
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:paddingEnd="4dp">

                    <TextView
                        android:id="@+id/tvCurrentTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Not Playing"
                        android:textColor="#F3F4F6"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:scrollHorizontally="true"
                        android:singleLine="true"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:duplicateParentState="true" />
                    
                    <TextView
                        android:id="@+id/tvCurrentArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--:-- / --:--"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"
                        android:ellipsize="end"
                        android:fontFamily="monospace"
                        android:singleLine="true"
                        android:duplicateParentState="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- 3. Play/Pause Button -->
            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/btn_focused_circle"
                android:src="@drawable/ic_play"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:stateListAnimator="@null"
                android:focusable="true"
                android:nextFocusLeft="@+id/btnOpenPlayer"
                android:nextFocusRight="@+id/btnNext"
                android:nextFocusUp="@+id/rvPlaylists"
                android:nextFocusDown="@+id/btnPlayPause"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnNext"
                app:layout_constraintTop_toTopOf="parent"
                android:contentDescription="play/pause"/>

            <!-- 4. Next Button -->
            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/btn_focused_circle"
                android:src="@drawable/ic_skip_next"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:stateListAnimator="@null"
                android:focusable="true"
                android:nextFocusLeft="@+id/btnPlayPause"
                android:nextFocusUp="@+id/rvPlaylists"
                android:nextFocusDown="@+id/btnNext"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:contentDescription="next"/>



        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <!-- Main Content: Songs -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSongs"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="24dp"
        android:nextFocusLeft="@+id/rvPlaylists"
        android:nextFocusUp="@+id/tvPlaylistTitle"
        app:layout_constraintStart_toEndOf="@+id/leftColumn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutHeaderRight"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
